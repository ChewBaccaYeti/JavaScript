        R0((0))
        N1((1))
        N2((2))
        N3((3))
        N1 --> R0
        N2 --> R0
        N3 --> N2
    end

    subgraph Set2["Set B (root=4)"]
        R4((4))
    end

    classDef root fill:#66bb6a,stroke:#66bb6a,color:#0f1419;
    classDef node fill:#232a3d,stroke:#4fc3f7,color:#e6e8ee;
    class R0,R4 root;
    class N1,N2,N3 node;
