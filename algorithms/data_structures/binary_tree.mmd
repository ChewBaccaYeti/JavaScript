---
title: Binary Search Tree (BST)
---
%% Свойство: value(left) < value(node) < value(right)
%% Avg: insert/search/delete = O(log n). Worst = O(n) (skewed).

graph TD
    R((5))
    A((3))
    B((7))
    C((1))
    D((4))
    E((6))
    F((8))

    R --> A
    R --> B
    A --> C
    A --> D
    B --> E
    B --> F

    classDef root fill:#4fc3f7,stroke:#4fc3f7,color:#0f1419;
    classDef leaf fill:#232a3d,stroke:#4fc3f7,color:#e6e8ee;
    class R root;
    class C,D,E,F leaf;
